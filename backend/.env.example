# LINE Bot 設定
# 若在本機測試可先設為 false，正式環境務必改回 true
LINE_ENABLE_SIGNATURE_VALIDATION=true
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# SQLite 資料庫設定（建議指向 ClawCloud Run 掛載磁碟）
# 範例：/data/rag_linebot/app.db
SQLITE_DB_PATH=./data/app.db

# Request Log 保留筆數上限
LINE_REQUEST_LOG_MAX_ENTRIES=1000
CHAT_REQUEST_LOG_MAX_ENTRIES=1000

# 共用 LLM 設定（LINE Bot 與 /api/v1/chat/completions 共用）
# 範例：https://api.openai.com/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL_ID=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_CONTEXT_WINDOW_SIZE=5
LLM_REQUEST_TIMEOUT_SECONDS=120
AGENT_MAX_ITERATIONS=8
RAG_TOP_K=8
RAG_CANDIDATE_MULTIPLIER=3
RAG_SCORE_THRESHOLD=0
LLM_SYSTEM_PROMPT='You are a professional and friendly customer service representative. Your task is to accurately answer user questions based on the provided [Database Information].
Please follow these guidelines:
Answer based on facts: Respond strictly based on the content in [Database Information].
Be honest: If there is no relevant information at all in [Database Information], politely inform the user: “Sorry, I’m currently unable to answer your question. You may contact a human customer service representative for further assistance.” Do not make up answers.
Keep it concise: Responses should be clear, well-structured, and focused on the key points. Avoid unnecessary lengthy explanations.
Language setting: Always respond in Traditional Chinese.
Professional tone: Maintain a polite, professional, and helpful attitude.
Do not ask follow-up questions: After answering the question, do not further extend the conversation with additional questions.'

# Qdrant 向量資料庫設定
QDRANT_URL=your_qdrant_url
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=rag_bge_m3
QDRANT_REQUEST_TIMEOUT_SECONDS=30

# Embedding API 設定 (BGE-M3)
EMBEDDING_API_URL=your_embedding_api_url
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120

# LINE Reply API 逾時秒數
LINE_REPLY_TIMEOUT_SECONDS=30
